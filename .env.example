# ===== LLM: OpenAI 직접 (폴백/로컬 테스트) =====
# OpenAI API 키. https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===== LLM: elice AI Cloud (OpenAI 호환, 역할별 티어) =====
# 공용 엔드포인트 (티어별 값이 비면 여기로 폴백). elice 모델 상세의 curl 예시에서 확인.
LLM_BASE_URL=
LLM_API_KEY=

# 티어별 엔드포인트·키·모델 (모델마다 전용 엔드포인트가 다르면 각각 채움).
# BASE_URL/API_KEY 를 비우면 위 공용(LLM_*)을 사용한다.
# 💰 크레딧 절약 팁: GPT-5.4는 output ₩23,625/1M로 비쌈(비추).
#    개발엔 gpt-4o-mini로 두고, 품질 필요한 reasoning만 저비용 추론모델로.
# reasoning → planner, itinerary  (추천: Nemotron 3 Ultra ₩750/₩3,900)
REASONING_BASE_URL=
REASONING_API_KEY=
REASONING_MODEL=openai/gpt-4o-mini
# standard → coordinator, destination, booking  (gpt-4o-mini 또는 GPT-5 mini)
STANDARD_BASE_URL=
STANDARD_API_KEY=
STANDARD_MODEL=openai/gpt-4o-mini
# fast → supervisor, payment  (추천: GPT-5 nano ₩79/₩630)
FAST_BASE_URL=
FAST_API_KEY=
FAST_MODEL=openai/gpt-4o-mini

# ===== 임베딩 (RAG 검색용, OpenAI 호환) =====
# elice "Text Embedding 3 Small" Dedicated 엔드포인트/키. model id는 elice에서 확인.
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=openai/text-embedding-3-small

# ===== 데이터베이스 (Postgres + pgvector) =====
# 로컬 개발: 프로젝트 docker-compose의 pgvector (호스트 5433). 로컬 Postgres(5432)와 안 겹침.
# docker-compose 내부 실행 시엔 environment의 db:5432 가 우선.
DATABASE_URL=postgresql+psycopg://tripagent:tripagent@localhost:5433/tripagent

# ===== 여행 데이터 API (선택 — 없으면 mock 폴백) =====
# 한국관광공사 TourAPI (국내 관광·숙박). https://www.data.go.kr/data/15101578/openapi.do
TOUR_API_KEY=
# Geoapify Places (해외 명소). 무료 3,000/day·카드X. https://myprojects.geoapify.com
GEOAPIFY_API_KEY=
# OpenTripMap (해외 명소, 미사용 — Geoapify로 대체). https://dev.opentripmap.org
OPENTRIPMAP_API_KEY=
# Duffel (해외 항공, 테스트). https://app.duffel.com/join
DUFFEL_API_KEY=
# LiteAPI (해외 호텔, 샌드박스). https://dashboard.liteapi.travel
LITEAPI_API_KEY=
# OpenWeatherMap (날씨, 선택). https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ===== 인증 (JWT) =====
# 액세스 토큰 서명 키. 운영에선 반드시 충분히 긴 랜덤값으로 교체(예: openssl rand -hex 32).
JWT_SECRET=dev-secret-change-me

# ===== 앱 설정 =====
# mock 폴백 강제 (실 API 무시하고 mock만 사용): true / false
USE_MOCK_ONLY=false
LOG_LEVEL=INFO
# CORS 허용 오리진 (프론트엔드 개발 서버)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
